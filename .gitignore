# =============================================================================
# CollabBoard — .gitignore
# =============================================================================

# -- Project documentation (local drafts) ------------------------------------
tmp/*

# -- Python -------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/

# -- Environment secrets ------------------------------------------------------
.env

# -- Runtime data (Docker volumes, uploads) -----------------------------------
data/

# -- TLS certificates ---------------------------------------------------------
certs/*.pem

# -- IDE ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -- OS -----------------------------------------------------------------------
.DS_Store
Thumbs.db