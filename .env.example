# =============================================================================
# CollabBoard — Environment Variables (.env.example)
# =============================================================================
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
#
# The `.env` file is git-ignored and should NEVER be committed.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_PASSWORD=changeme

# -- Backend (for running locally outside Docker) ----------------------------
DATABASE_URL=postgresql://collabboard:changeme@localhost:5432/collabboard
REDIS_URL=redis://localhost:6379/0
SERVER_ID=local-dev
